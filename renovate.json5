{
  extends: [
    'github>cybozu/renovate-config',
    ':prConcurrentLimitNone',
  ],
  ignorePaths: [
    '**/node_modules/**',
    '**/bower_components/**',
    '**/vendor/**',
    '**/__tests__/**',
    '**/test/**',
    '**/tests/**',
    '**/__fixtures__/**',
  ],
  npm: {
    managerFilePatterns: [
      '/^packages/create-plugin/templates/([^/]+/)*with-plugin-uploader\\.json$/',
    ],
    packageRules: [
      {
        semanticCommitType: 'chore',
        matchPackageNames: [
          '*',
        ],
      },
      {
        matchDepTypes: [
          'devDependencies',
        ],
        matchUpdateTypes: [
          'minor',
        ],
        automerge: true,
        matchPackageNames: [
          '*',
        ],
      },
    ],
  },
  customManagers: [
    {
      customType: 'regex',
      managerFilePatterns: [
        '/^packages/create-plugin/src/manifest\\.ts$/',
      ],
      matchStrings: [
        'plugin-manifest-validator%40(?<currentValue>[0-9]+\\.[0-9]+\\.[0-9]+)',
      ],
      depNameTemplate: '@kintone/plugin-manifest-validator',
      datasourceTemplate: 'npm',
    },
  ],
  packageRules: [
    {
      matchPackageNames: [
        '@kintone/plugin-manifest-validator',
      ],
      matchManagers: [
        'custom.regex',
      ],
      semanticCommitType: 'chore',
    },
    {
      matchDepTypes: [
        'dependencies',
      ],
      rangeStrategy: 'bump',
    },
    {
      groupName: 'axios and related deps',
      matchPackageNames: [
        'axios',
        'form-data',
      ],
      matchDepTypes: [
        'dependencies',
      ],
    },
    {
      groupName: 'openapi ecosystem deps',
      matchPackageNames: [
        'openapi-fetch',
        'openapi-typescript',
        'openapi-typescript-helpers',
      ],
      matchDepTypes: [
        'dependencies',
      ],
    },
    {
      groupName: 'ajv ecosystem deps',
      matchPackageNames: [
        'ajv',
        'ajv-formats',
      ],
      matchDepTypes: [
        'dependencies',
      ],
    },
    {
      matchDepTypes: [
        'action',
      ],
      pinDigests: true,
      matchPackageNames: [
        '!actions/{/,}**',
        '!cybozu/{/,}**',
      ],
    },
  ],
}
